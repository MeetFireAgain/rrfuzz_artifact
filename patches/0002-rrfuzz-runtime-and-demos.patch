+            /* Capture buffer data */
+            if (args[1] != 0 && args[2] > 0 && args[2] <= RR_MAX_BUFFER_TOTAL) {
+#ifdef TARGET_NR_pread64
+                if (syscall_nr == TARGET_NR_pread64 && ret > 0) {
