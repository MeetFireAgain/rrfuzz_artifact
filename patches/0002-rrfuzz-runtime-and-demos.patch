+                alog(f"🔧 Auto-detected QEMU_LD_PREFIX: {best_root}", "EXEC", "INFO")
+            # else: native execution or can't be inferred
+            # else: native execution or can't be inferred, don't set it (x86_64 on x86_64)
+        
+        if 'RR_TREE_OUTPUT' in env:
