+            success = random.random() < 0.3
+            new_cov = random.randint(0, 5) if success else 0
+            pool.update_recipe_result(recipe, success, new_cov)
+    
+    # Print summary
+    pool.print_summary()
+    
+    print("✅ RecipePool test passed")
+
+
+if __name__ == '__main__':
+    test_recipe_pool()
+
